      "url": "https://habitat.network/xrpc",
      "description": "Habitat XRPC server"
    }
  ],
  "paths": {
    "/network.habitat.clique.addMembers": {
      "post": {
        "tags": [
          "network.habitat.clique"
        ],
        "summary": "network.habitat.clique.addMembers",
        "description": "Add member(s) to a clique. The clique must be editable by the caller.",
        "operationId": "network.habitat.clique.addMembers",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "clique",
                  "members"
                ],
                "properties": {
                  "clique": {
                    "$ref": "#/components/schemas/network.habitat.grantee.clique"
                  },
                  "members": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "format": "did"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "error",
                    "message"
                  ],
                  "properties": {
                    "error": {
                      "type": "string",
                      "oneOf": [
                        {
                          "const": "InvalidRequest"
                        }
                      ]
                    },
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
