    "/network.habitat.repo.createRecord": {
      "post": {
        "tags": [
          "network.habitat.repo"
        ],
        "summary": "network.habitat.repo.createRecord",
        "description": "Create a pear repository record, creating it if it does not exist already, or updating it as needed.",
        "operationId": "network.habitat.repo.createRecord",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "repo",
                  "collection",
                  "record"
                ],
                "properties": {
                  "repo": {
                    "type": "string",
                    "description": "The handle or DID of the repo (aka, current account).",
                    "format": "at-identifier"
                  },
                  "collection": {
                    "type": "string",
                    "description": "The NSID of the record collection.",
                    "format": "nsid"
                  },
                  "rkey": {
                    "type": "string",
                    "description": "The Record Key.",
                    "format": "record-key",
                    "maxLength": 512
                  },
                  "validate": {
                    "type": "boolean",
                    "description": "Can be set to 'false' to skip Lexicon schema validation of record data, 'true' to require it, or leave unset to validate only for known Lexicons."
                  },
                  "record": {},
                  "createGranteesClique": {
                    "type": "boolean",
                    "description": "Whether to create a clique with the given grantees. If true, all grantees must be DIDs, and the created clique ref is returned."
                  },
                  "grantees": {
                    "type": "array",
                    "items": {
                      "oneOf": [
                        {
                          "$ref": "#/components/schemas/network.habitat.grantee.didGrantee"
                        },
                        {
                          "$ref": "#/components/schemas/network.habitat.grantee.clique"
                        }
                      ]
                    },
                    "maxItems": 100
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "uri"
                  ],
                  "properties": {
                    "uri": {
                      "type": "string",
                      "description": "The habitat-uri of the put-ed object.",
                      "format": "uri"
                    },
                    "validationStatus": {
                      "type": "string",
                      "enum": [
                        "valid",
                        "unknown"
                      ]
                    },
                    "clique": {
                      "type": "string",
                      "description": "If a clique was created, return its ref, formatted like clique:<owner did>/<clique key>"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "error",
                    "message"
                  ],
                  "properties": {
                    "error": {
                      "type": "string",
                      "oneOf": [
                        {
                          "const": "InvalidRequest"
                        }
                      ]
                    },
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
