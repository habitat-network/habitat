  "info": {
    "title": "Habitat API",
    "summary": "OpenAPI spec generated from Habitat's AT Protocol lexicons.",
    "description": "Welcome to the Habitat API reference! We are currently under development and our API may make breaking changes without notice. Stay tuned @habitat.network on Bluesky and habitat.leaflet.pub for formal releases.",
