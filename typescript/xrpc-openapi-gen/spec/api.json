                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/network.habitat.permissions.addPermission": {
      "post": {
        "tags": [
          "network.habitat.permissions"
        ],
        "summary": "network.habitat.permissions.addPermission",
        "description": "Grant read permission to a user or a clique for a specific collection or a specific record.",
        "operationId": "network.habitat.permissions.addPermission",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "grantees",
                  "collection"
                ],
                "properties": {
                  "grantees": {
                    "type": "array",
                    "items": {
                      "oneOf": [
                        {
                          "$ref": "#/components/schemas/network.habitat.grantee.didGrantee"
                        },
                        {
                          "$ref": "#/components/schemas/network.habitat.grantee.clique"
                        }
                      ]
                    },
                    "maxItems": 100
                  },
                  "collection": {
                    "type": "string",
                    "description": "The NSID of the lexicon or record to grant read permission for.",
                    "format": "nsid"
                  },
                  "rkey": {
                    "type": "string",
                    "description": "The Record Key to grant read permissions to, if any.",
                    "format": "record-key",
                    "maxLength": 512
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "error",
                    "message"
                  ],
                  "properties": {
                    "error": {
                      "type": "string",
                      "oneOf": [
                        {
                          "const": "InvalidRequest"
                        }
                      ]
                    },
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
