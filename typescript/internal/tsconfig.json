{
  "extends": "../../tsconfig.options.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "noEmitOnError": true,
    "noEmit": false,
    "emitDeclarationOnly": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*", "../globals.d.ts"],
  "references": [
    {
      "path": "../api"
    }
  ]
}
