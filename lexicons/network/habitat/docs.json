{
    "lexicon": 1,
    "id": "network.habitat.docs",
    "defs": {
        "main": {
            "type": "record",
            "description": "A collaborative document.",
            "key": "tid",
            "record": {
                "type": "object",
                "required": [
                    "name",
                    "blob"
                ],
                "properties": {
                    "name": {
                        "type": "string",
                        "description": "The name of the document, derived from the first heading."
                    },
                    "blob": {
                        "type": "string",
                        "description": "Base64-encoded Yjs state update representing the document content."
                    },
                    "editorClique": {
                        "type": "string",
                        "format": "uri",
                        "description": "URI of the clique whose members may edit this document."
                    },
                    "isPublic": {
                        "type": "boolean",
                        "description": "Whether this document is stored on the public AT Proto PDS and readable by anyone."
                    }
                }
            }
        }
    }
}
