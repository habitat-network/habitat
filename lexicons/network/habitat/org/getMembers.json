{
    "lexicon": 1,
    "id": "network.habitat.org.getMembers",
    "defs": {
        "main": {
            "type": "query",
            "description": "Get the list of members in the org. Callable by any org member.",
            "output": {
                "encoding": "application/json",
                "schema": {
                    "type": "object",
                    "required": [
                        "members"
                    ],
                    "properties": {
                        "members": {
                            "type": "array",
                            "items": {
                                "type": "ref",
                                "ref": "network.habitat.org.getMembers#member"
                            }
                        }
                    }
                }
            }
        },
        "member": {
            "type": "object",
            "required": [
                "did",
                "handle"
            ],
            "properties": {
                "did": {
                    "type": "string",
                    "format": "did"
                },
                "handle": {
                    "type": "string"
                }
            }
        }
    }
}
