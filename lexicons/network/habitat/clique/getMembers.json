{
    "lexicon": 1,
    "id": "network.habitat.clique.getMembers",
    "defs": {
        "main": {
            "type": "query",
            "description": "See the member(s) to a clique. The clique must be readable by the caller.",
            "parameters": {
                "type": "params",
                "required": [
                    "clique"
                ],
                "properties": {
                    "clique": {
                        "type": "string",
                        "description": "The desired clique to query formatted as clique:<owner did>/<clique key>"
                    }
                }
            },
            "output": {
                "encoding": "application/json",
                "schema": {
                    "type": "object",
                    "required": [
                        "members"
                    ],
                    "properties": {
                        "members": {
                            "type": "array",
                            "items": {
                                "type": "string",
                                "format": "did"
                            }
                        }
                    }
                }
            }
        }
    }
}