{
  "lexicon": 1,
  "id": "network.habitat.space.getBlob",
  "defs": {
    "main": {
      "type": "query",
      "description": "Get a blob stored within a permissioned space, addressed by its CID. Requires read access to the space.",
      "parameters": {
        "type": "params",
        "required": ["space", "cid"],
        "properties": {
          "space": {
            "type": "string",
            "format": "at-uri",
            "description": "Reference to the space the blob belongs to."
          },
          "cid": {
            "type": "string",
            "format": "cid",
            "description": "The CID of the blob to fetch."
          }
        }
      },
      "output": {
        "encoding": "*/*"
      },
      "errors": [
        { "name": "BlobNotFound" },
        { "name": "SpaceNotFound" }
      ]
    }
  }
}
