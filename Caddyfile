{
	log {
		format console
		level warn
	}
}

frontend.local.habitat.network {
	reverse_proxy 127.0.0.1:6000
	tls internal
}

docs.local.habitat.network {
	reverse_proxy 127.0.0.1:5175
	tls internal
}

docsv2.local.habitat.network {
	reverse_proxy 127.0.0.1:5176
	tls internal
}

# Docs server: holds the org credential, persists canonical docs via pear, and
# serves its did:web doc so pear can resolve did:web:docs-server.local.habitat.network
# and forward network.habitat.doc.* calls to it.
docs-server.local.habitat.network {
	reverse_proxy 127.0.0.1:2590
	tls internal
}

*.*.pear.local.habitat.network,
*.pear.local.habitat.network,
pear.local.habitat.network {
	reverse_proxy 127.0.0.1:8000
	tls internal {
		on_demand
	}
}

sap.local.habitat.network {
    reverse_proxy 127.0.0.1:2580
    tls internal
}
