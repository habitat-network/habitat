---
import Icon from "./Icon.astro";

---

<div class="announcement-bar sticky top-0 z-20">
  <p>
    Summer in Berlin! Habitat will be at <a href="https://dwebcamp.org" target="_blank" rel="noopener noreferrer">DWeb Camp</a> and <a href="https://www.localfirstconf.com" target="_blank" rel="noopener noreferrer">Local-First Conf</a> July 8-15th.
    <a href="mailto:hello@habitat.network">Reach out and meet us there &rarr;</a>
  </p>
</div>

<header class="header-sticky flex justify-between px-6 py-4 items-center sticky z-10 bg-white">
  <div class="flex items-center gap-6">
    <a href="/" class="wordmark-link"><img src="/habitat-wordmark.svg" class="w-32" /></a>
    <a href="https://habitat.network/habitat/api" class="hidden md:block docs-link">Documentation</a>
    <a href="/community-platform" class="hidden md:block docs-link">Community Platform</a>
  </div>

  <div class="hidden md:flex items-center gap-6">
    <a href="https://github.com/habitat-network/habitat" aria-label="GitHub">
      <Icon name="github" class="w-6 h-6" />
    </a>
    <a href="https://bsky.app/profile/habitat.network" aria-label="Bluesky">
      <Icon name="bluesky" class="w-6 h-6" />
    </a>
    <a href="https://habitat.leaflet.pub" aria-label="Leaflet">
      <Icon name="leaflet" class="w-6 h-6" />
    </a>
  </div>

  <!-- Mobile menu -->
  <details class="md:hidden relative">
    <summary class="list-none cursor-pointer [&::-webkit-details-marker]:hidden">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </summary>
    <div class="absolute right-0 top-full mt-2 bg-white border border-gray-300 rounded-lg p-4 flex flex-col gap-4 min-w-56 shadow-lg z-20">
      <a href="https://habitat.network/habitat/api" class="text-black no-underline text-sm">Documentation</a>
      <a href="/community-platform" class="text-black no-underline text-sm">Community Platform</a>
      <div class="border-t border-gray-200 pt-3 flex gap-4">
        <a href="https://github.com/habitat-network/habitat" aria-label="GitHub">
          <Icon name="github" class="w-6 h-6" />
        </a>
        <a href="https://bsky.app/profile/habitat.network" aria-label="Bluesky">
          <Icon name="bluesky" class="w-6 h-6" />
        </a>
        <a href="https://habitat.leaflet.pub" aria-label="Leaflet">
          <Icon name="leaflet" class="w-6 h-6" />
        </a>
      </div>
    </div>
  </details>
</header>

<style>
  :root {
    --announcement-height: 2.25rem;
    --pink: #EB2EB3
  }

  .announcement-bar {
    height: var(--announcement-height);
    display: flex;
    align-items: center;
    justify-content: center;
    background: #008000;
    padding: 0 1.5rem;
  }
  .announcement-bar p {
    margin: 0;
    color: #fff;
    font-family: 'General Sans', ui-sans-serif, system-ui, sans-serif;
    font-size: 0.875rem;
    font-weight: 400;
    text-align: center;
    letter-spacing: -0.005em;
  }
  .announcement-bar a {
    color: #fff;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .announcement-bar a:hover {
    transform: none;
    color: var(--pink);
  }

  .header-sticky {
    top: var(--announcement-height);
  }

  .wordmark-link:hover {
    transform: none;
  }

  .docs-link {
    font-family: 'General Sans', ui-sans-serif, system-ui, sans-serif;
    font-size: 1.25rem;
    font-weight: 400;
    color: #000;
    text-decoration: none;
    letter-spacing: -0.005em;
    transition: color 160ms ease;
  }
  .docs-link:hover {
    color: #008000;
    transform: none;
    text-decoration: none;
  }
</style>
