---
import Icon from "./Icon.astro";

interface Props {
  active?: "users" | "developers";
}

const { active } = Astro.props;
---

<header class="flex justify-between px-6 py-4 items-center sticky top-0 z-10 bg-[#f4f4f4]">
  <div class="flex-1">
    <a href="/"><img src="/habitat-wordmark.svg" class="w-32" /></a>
  </div>

  <!-- Desktop nav -->
  <nav class="hidden md:flex text-lg gap-8">
    <a href="/users">{active === "users" ? <u>For users</u> : "For users"}</a>
    <a href="/developers">{active === "developers" ? <u>For developers</u> : "For developers"}</a>
  </nav>
  <div class="hidden md:flex flex-1 justify-end gap-4 items-center">
    <a href="https://github.com/habitat-network/habitat" aria-label="GitHub">
      <Icon name="github" class="w-6 h-6" />
    </a>
    <a href="https://bsky.app/profile/habitat.network" aria-label="Bluesky">
      <Icon name="bluesky" class="w-6 h-6" />
    </a>
    <a href="https://habitat.leaflet.pub" aria-label="Leaflet">
      <Icon name="leaflet" class="w-6 h-6" />
    </a>
  </div>

  <!-- Mobile menu -->
  <details class="md:hidden relative">
    <summary class="list-none cursor-pointer">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </summary>
    <div class="absolute right-0 top-full mt-2 bg-[#f4f4f4] border border-gray-300 rounded-lg p-4 flex flex-col gap-4 min-w-48 shadow-lg z-20">
      <nav class="flex flex-col gap-3 text-lg">
        <a href="/users">{active === "users" ? <u>For users</u> : "For users"}</a>
        <a href="/developers">{active === "developers" ? <u>For developers</u> : "For developers"}</a>
      </nav>
      <hr class="border-gray-300" />
      <div class="flex gap-4">
        <a href="https://github.com/habitat-network/habitat" aria-label="GitHub">
          <Icon name="github" class="w-6 h-6" />
        </a>
        <a href="https://bsky.app/profile/habitat.network" aria-label="Bluesky">
          <Icon name="bluesky" class="w-6 h-6" />
        </a>
        <a href="https://habitat.leaflet.pub" aria-label="Leaflet">
          <Icon name="leaflet" class="w-6 h-6" />
        </a>
      </div>
    </div>
  </details>
</header>
