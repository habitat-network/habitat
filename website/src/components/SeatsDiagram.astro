---
// "Pay for the people who actually need to use the product."
// Three paid seats on the left funnel through a single "Paid app" box up to
// the org data. Seven viewers on the right access the data directly via
// habitat without a paid seat.
---

<div class="seats-diagram">
  <svg viewBox="0 0 640 300" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Three paid app seats and seven viewers all accessing your data">
    <!-- Data bar (top) -->
    <g class="data-bar">
      <rect x="20" y="20" width="600" height="50" rx="8" />
      <text x="320" y="51" class="data-label">Your data</text>
    </g>

    <!-- Paid app box (middle, left side) -->
    <g class="app-box">
      <rect x="30" y="110" width="160" height="40" rx="8" />
      <text x="110" y="135" class="app-label">Paid app</text>
    </g>

    <!-- Paid: 3 people -> Paid app -->
    <path id="seat-p0" class="wire" d="M 50 192 L 50 150" />
    <path id="seat-p1" class="wire" d="M 110 192 L 110 150" />
    <path id="seat-p2" class="wire" d="M 170 192 L 170 150" />

    <!-- Paid app -> Your data -->
    <path id="seat-app" class="wire" d="M 110 110 L 110 70" />

    <!-- Free: 7 viewers -> Your data (direct) -->
    <path id="seat-v0" class="wire" d="M 230 192 L 230 70" />
    <path id="seat-v1" class="wire" d="M 290 192 L 290 70" />
    <path id="seat-v2" class="wire" d="M 350 192 L 350 70" />
    <path id="seat-v3" class="wire" d="M 410 192 L 410 70" />
    <path id="seat-v4" class="wire" d="M 470 192 L 470 70" />
    <path id="seat-v5" class="wire" d="M 530 192 L 530 70" />
    <path id="seat-v6" class="wire" d="M 590 192 L 590 70" />

    <!-- Pulses -->
    <circle r="3.5" class="pulse"><animateMotion dur="2.6s" repeatCount="indefinite" begin="0s"><mpath href="#seat-p0" /></animateMotion></circle>
    <circle r="3.5" class="pulse"><animateMotion dur="2.6s" repeatCount="indefinite" begin="0.3s"><mpath href="#seat-p1" /></animateMotion></circle>
    <circle r="3.5" class="pulse"><animateMotion dur="2.6s" repeatCount="indefinite" begin="0.6s"><mpath href="#seat-p2" /></animateMotion></circle>
    <circle r="3.5" class="pulse"><animateMotion dur="2.6s" repeatCount="indefinite" begin="1.0s"><mpath href="#seat-app" /></animateMotion></circle>

    <circle r="3.5" class="pulse"><animateMotion dur="2.6s" repeatCount="indefinite" begin="0s"><mpath href="#seat-v0" /></animateMotion></circle>
    <circle r="3.5" class="pulse"><animateMotion dur="2.6s" repeatCount="indefinite" begin="0.3s"><mpath href="#seat-v1" /></animateMotion></circle>
    <circle r="3.5" class="pulse"><animateMotion dur="2.6s" repeatCount="indefinite" begin="0.6s"><mpath href="#seat-v2" /></animateMotion></circle>
    <circle r="3.5" class="pulse"><animateMotion dur="2.6s" repeatCount="indefinite" begin="0.9s"><mpath href="#seat-v3" /></animateMotion></circle>
    <circle r="3.5" class="pulse"><animateMotion dur="2.6s" repeatCount="indefinite" begin="1.2s"><mpath href="#seat-v4" /></animateMotion></circle>
    <circle r="3.5" class="pulse"><animateMotion dur="2.6s" repeatCount="indefinite" begin="1.5s"><mpath href="#seat-v5" /></animateMotion></circle>
    <circle r="3.5" class="pulse"><animateMotion dur="2.6s" repeatCount="indefinite" begin="1.8s"><mpath href="#seat-v6" /></animateMotion></circle>

    <!-- People row -->
    <!-- Paid (left, filled) -->
    <g class="person paid">
      <circle cx="50" cy="200" r="8" />
      <path d="M 38 230 Q 38 212 50 212 Q 62 212 62 230 Z" />
      <circle cx="62" cy="194" r="9" class="badge" />
      <text x="62" y="198" class="badge-text">$</text>
    </g>
    <g class="person paid">
      <circle cx="110" cy="200" r="8" />
      <path d="M 98 230 Q 98 212 110 212 Q 122 212 122 230 Z" />
      <circle cx="122" cy="194" r="9" class="badge" />
      <text x="122" y="198" class="badge-text">$</text>
    </g>
    <g class="person paid">
      <circle cx="170" cy="200" r="8" />
      <path d="M 158 230 Q 158 212 170 212 Q 182 212 182 230 Z" />
      <circle cx="182" cy="194" r="9" class="badge" />
      <text x="182" y="198" class="badge-text">$</text>
    </g>

    <!-- Viewers (right, outlined) -->
    <g class="person viewer">
      <circle cx="230" cy="200" r="8" />
      <path d="M 218 230 Q 218 212 230 212 Q 242 212 242 230 Z" />
    </g>
    <g class="person viewer">
      <circle cx="290" cy="200" r="8" />
      <path d="M 278 230 Q 278 212 290 212 Q 302 212 302 230 Z" />
    </g>
    <g class="person viewer">
      <circle cx="350" cy="200" r="8" />
      <path d="M 338 230 Q 338 212 350 212 Q 362 212 362 230 Z" />
    </g>
    <g class="person viewer">
      <circle cx="410" cy="200" r="8" />
      <path d="M 398 230 Q 398 212 410 212 Q 422 212 422 230 Z" />
    </g>
    <g class="person viewer">
      <circle cx="470" cy="200" r="8" />
      <path d="M 458 230 Q 458 212 470 212 Q 482 212 482 230 Z" />
    </g>
    <g class="person viewer">
      <circle cx="530" cy="200" r="8" />
      <path d="M 518 230 Q 518 212 530 212 Q 542 212 542 230 Z" />
    </g>
    <g class="person viewer">
      <circle cx="590" cy="200" r="8" />
      <path d="M 578 230 Q 578 212 590 212 Q 602 212 602 230 Z" />
    </g>

    <!-- Caption row -->
    <text x="320" y="275" class="caption">3 paid seats · 10 people with data access</text>
  </svg>
</div>

<style>
  .seats-diagram {
    width: 100%;
    max-width: 640px;
    margin: 0 auto;
    padding: 1rem 0;
  }

  .seats-diagram svg {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Data bar */
  .data-bar rect {
    fill: #fafafa;
    stroke: #1f1f1f;
    stroke-width: 1.5;
  }

  .data-label {
    fill: #1f1f1f;
    font-size: 16px;
    font-weight: 600;
    text-anchor: middle;
    font-family: inherit;
  }

  /* Paid app box */
  .app-box rect {
    fill: #fafafa;
    stroke: #1f1f1f;
    stroke-width: 1.5;
  }
  .app-label {
    fill: #1f1f1f;
    font-size: 15px;
    font-weight: 600;
    text-anchor: middle;
    font-family: inherit;
  }

  /* Wires */
  .wire {
    fill: none;
    stroke: #1f1f1f;
    stroke-width: 1.25;
    stroke-opacity: 0.2;
    stroke-dasharray: 3 5;
  }

  .pulse {
    fill: #1f1f1f;
    filter: drop-shadow(0 0 5px rgba(31, 31, 31, 0.4));
  }

  /* People */
  .person.paid circle:not(.badge),
  .person.paid path {
    fill: #1f1f1f;
    stroke: #1f1f1f;
    stroke-width: 1.25;
  }

  .person.viewer circle,
  .person.viewer path {
    fill: #fafafa;
    stroke: #1f1f1f;
    stroke-width: 1.25;
  }

  .badge {
    fill: #fafafa;
    stroke: #1f1f1f;
    stroke-width: 1.25;
  }

  .badge-text {
    fill: #1f1f1f;
    font-size: 11px;
    font-weight: 700;
    text-anchor: middle;
    font-family: inherit;
  }

  .caption {
    fill: #1f1f1f;
    font-size: 14px;
    font-weight: 500;
    text-anchor: middle;
    font-family: inherit;
    opacity: 0.7;
  }

  @media (prefers-reduced-motion: reduce) {
    .pulse { display: none; }
    .wire { stroke-opacity: 0.4; stroke-dasharray: none; }
  }
</style>
