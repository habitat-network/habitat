---
// Animated diagram: "You" requests data from three SaaS providers.
// Pulses travel from You (bottom) up to each SaaS box (top).
---

<div class="old-way-diagram">
  <svg viewBox="0 0 600 360" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="You requesting data from SaaS providers">
    <defs>
      <!-- Pulse gradient: bright head, fading tail -->
      <linearGradient id="pulseGrad" x1="0%" y1="0%" x2="0%" y2="100%">
        <stop offset="0%" stop-color="#1f1f1f" stop-opacity="0" />
        <stop offset="60%" stop-color="#1f1f1f" stop-opacity="0.35" />
        <stop offset="100%" stop-color="#1f1f1f" stop-opacity="1" />
      </linearGradient>
    </defs>

    <!-- SaaS boxes (top row) -->
    <g class="saas-box">
      <rect x="40"  y="30" width="140" height="70" rx="10" />
      <text x="110" y="71">SaaS #1</text>
    </g>
    <g class="saas-box">
      <rect x="230" y="30" width="140" height="70" rx="10" />
      <text x="300" y="71">SaaS #2</text>
    </g>
    <g class="saas-box">
      <rect x="420" y="30" width="140" height="70" rx="10" />
      <text x="490" y="71">SaaS #3</text>
    </g>

    <!-- Connector paths from You (top edge ~y=260) up to each SaaS (bottom edge y=100) -->
    <!-- Path 1: You -> SaaS #1 -->
    <path id="p1" class="wire" d="M 260 260 C 220 220, 150 160, 110 100" />
    <!-- Path 2: You -> SaaS #2 (straight) -->
    <path id="p2" class="wire" d="M 300 260 L 300 100" />
    <!-- Path 3: You -> SaaS #3 -->
    <path id="p3" class="wire" d="M 340 260 C 380 220, 450 160, 490 100" />

    <!-- Pulse heads traveling along paths -->
    <circle r="4" class="pulse pulse-1">
      <animateMotion dur="2.4s" repeatCount="indefinite" rotate="auto" begin="0s">
        <mpath href="#p1" />
      </animateMotion>
    </circle>
    <circle r="4" class="pulse pulse-2">
      <animateMotion dur="2.4s" repeatCount="indefinite" rotate="auto" begin="0.8s">
        <mpath href="#p2" />
      </animateMotion>
    </circle>
    <circle r="4" class="pulse pulse-3">
      <animateMotion dur="2.4s" repeatCount="indefinite" rotate="auto" begin="1.6s">
        <mpath href="#p3" />
      </animateMotion>
    </circle>

    <!-- "You" box (bottom center) -->
    <g class="you-box">
      <rect x="240" y="260" width="120" height="70" rx="10" />
      <text x="300" y="301">You</text>
    </g>
  </svg>
</div>

<style>
  .old-way-diagram {
    width: 100%;
    max-width: 640px;
    margin: 0 auto;
    padding: 1rem 0;
  }

  .old-way-diagram svg {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Box styling */
  .saas-box rect,
  .you-box rect {
    fill: #fafafa;
    stroke: #1f1f1f;
    stroke-width: 1.5;
  }

  .you-box rect {
    fill: #1f1f1f;
  }

  .saas-box text {
    fill: #1f1f1f;
    font-size: 18px;
    font-weight: 600;
    text-anchor: middle;
    font-family: inherit;
  }

  .you-box text {
    fill: #fafafa;
    font-size: 18px;
    font-weight: 600;
    text-anchor: middle;
    font-family: inherit;
  }

  /* Wires */
  .wire {
    fill: none;
    stroke: #1f1f1f;
    stroke-width: 1.5;
    stroke-opacity: 0.18;
    stroke-dasharray: 4 6;
  }

  /* Pulse heads */
  .pulse {
    fill: #1f1f1f;
  }

  /* Subtle glow trail behind each pulse using drop-shadow */
  .pulse-1, .pulse-2, .pulse-3 {
    filter: drop-shadow(0 0 6px rgba(31, 31, 31, 0.45));
  }

  @media (prefers-reduced-motion: reduce) {
    .pulse { display: none; }
    .wire { stroke-opacity: 0.4; stroke-dasharray: none; }
  }
</style>
