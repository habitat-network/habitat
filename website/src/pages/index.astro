---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import "../styles/landing.css";
---

<Layout
  title="Habitat"
  description="A unified layer for your organization's data."
>
  <Header />

  <main class="landing">
    <!-- HERO -->
    <section class="hero">
      <div class="hero-inner">
        <div class="hero-copy">
          <h1 class="display reveal">Own your data.</h1>
          <p class="hero-sub reveal" style="--d: 120ms">
            Habitat is an open-source data ownership layer for organizations, so your data works better for you. Make vendor lock-in, clunky cross-app workflows, and incompatible permissions a thing of the past. Learn how to take back control over your data now.
          </p>
<!-- Calendly link widget begin -->
<link href="https://assets.calendly.com/assets/external/widget.css" rel="stylesheet">
<script src="https://assets.calendly.com/assets/external/widget.js" type="text/javascript" async></script>
<div class="reveal" style="--d: 180ms; margin-bottom: 32px;">
  <a class="cta-button cta-green hero-talk-to-us" href="" onclick="Calendly.initPopupWidget({url: 'https://calendly.com/arushi-habitat'});return false;">Talk to us</a>
</div>
<!-- Calendly link widget end -->

          <form class="waitlist reveal" style="--d: 220ms" novalidate>
            <label class="visually-hidden" for="email-hero">your email</label>
            <input id="email-hero" type="text" name="email" placeholder="your email" required />
            <button type="submit">Or sign up for updates<span aria-hidden="true">→</span></button>
          </form>
          <p class="waitlist-status reveal" data-status="idle" aria-live="polite"></p>
        </div>

        <div class="hero-visual reveal" style="--d: 400ms" aria-hidden="true">
         <div class="hero-art-wrap">
          <svg class="hero-art" viewBox="0 0 500 600" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
            <defs>
              <pattern id="heroTile" x="0" y="0" width="100" height="100" patternUnits="userSpaceOnUse">
                <rect x="5" y="5" width="90" height="90" fill="none" stroke="rgba(0,0,0,0.22)" stroke-width="1"/>
              </pattern>
              <linearGradient id="heroFadeGrad" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%"  stop-color="white" stop-opacity="0"/>
                <stop offset="22%" stop-color="white" stop-opacity="1"/>
                <stop offset="100%" stop-color="white" stop-opacity="1"/>
              </linearGradient>
              <mask id="heroFadeMask">
                <rect width="500" height="600" fill="url(#heroFadeGrad)"/>
              </mask>

            </defs>

            <rect width="500" height="600" fill="url(#heroTile)" mask="url(#heroFadeMask)"/>
          </svg>
          <canvas class="hero-falling-canvas" aria-hidden="true"></canvas>
         </div>
        </div>
      </div>
    </section>

    <!-- SECTION 1: THE SHIFT -->
    <section class="section shift">
      <div class="section-inner">
        <h2 class="reveal">We're building your data's forever home.</h2>
        <p class="lead reveal" style="--d: 100ms">
          Today, your data belongs to SaaS providers. Each provider is siloed and limits access through their APIs, making data less useful and integrated agentic workflows harder. Habitat changes that.
        </p>

        <div class="diagram reveal" style="--d: 200ms" aria-hidden="true">
          <div class="diagram-col">
            <div class="diagram-label">Today</div>
            <svg class="silo-svg" viewBox="0 0 400 360" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet">
              <defs>
                <filter id="wallBlur" x="-100%" y="-20%" width="300%" height="140%">
                  <feGaussianBlur stdDeviation="3"/>
                </filter>
                <filter id="orbGlow2" x="-300%" y="-300%" width="700%" height="700%">
                  <feGaussianBlur stdDeviation="2.6" result="b"/>
                  <feMerge>
                    <feMergeNode in="b"/>
                    <feMergeNode in="b"/>
                    <feMergeNode in="SourceGraphic"/>
                  </feMerge>
                </filter>
              </defs>

              <!-- Silo 1 -->
              <g transform="translate(70 0)">
                <rect class="node" x="-44" y="20" width="88" height="40" rx="1"/>
                <text class="node-label" x="0" y="45" text-anchor="middle">SaaS #1</text>
                <line class="wall" x1="-44" y1="72" x2="-44" y2="305"/>
                <line class="wall" x1="44"  y1="72" x2="44"  y2="305"/>
                <circle class="person" cx="0" cy="170" r="7"/>
                <path class="person" d="M-13 200 Q-13 184 0 184 Q13 184 13 200"/>
                <circle class="orb" cx="0" cy="65" r="2.5" opacity="0" filter="url(#orbGlow2)">
                  <animate attributeName="cy" values="65;155;65" dur="4.4s" begin="0s" repeatCount="indefinite"/>
                  <animate attributeName="opacity" values="0;1;1;1;0" keyTimes="0;0.1;0.45;0.85;1" dur="4.4s" begin="0s" repeatCount="indefinite"/>
                </circle>
              </g>

              <!-- Silo 2 -->
              <g transform="translate(200 0)">
                <rect class="node" x="-44" y="20" width="88" height="40" rx="1"/>
                <text class="node-label" x="0" y="45" text-anchor="middle">SaaS #2</text>
                <line class="wall" x1="-44" y1="72" x2="-44" y2="305"/>
                <line class="wall" x1="44"  y1="72" x2="44"  y2="305"/>
                <circle class="person" cx="0" cy="170" r="7"/>
                <path class="person" d="M-13 200 Q-13 184 0 184 Q13 184 13 200"/>
                <circle class="orb" cx="0" cy="65" r="2.5" opacity="0" filter="url(#orbGlow2)">
                  <animate attributeName="cy" values="65;155;65" dur="4.4s" begin="0.6s" repeatCount="indefinite"/>
                  <animate attributeName="opacity" values="0;1;1;1;0" keyTimes="0;0.1;0.45;0.85;1" dur="4.4s" begin="0.6s" repeatCount="indefinite"/>
                </circle>
              </g>

              <!-- Silo 3 -->
              <g transform="translate(330 0)">
                <rect class="node" x="-44" y="20" width="88" height="40" rx="1"/>
                <text class="node-label" x="0" y="45" text-anchor="middle">SaaS #3</text>
                <line class="wall" x1="-44" y1="72" x2="-44" y2="305"/>
                <line class="wall" x1="44"  y1="72" x2="44"  y2="305"/>
                <circle class="person" cx="0" cy="170" r="7"/>
                <path class="person" d="M-13 200 Q-13 184 0 184 Q13 184 13 200"/>
                <circle class="orb" cx="0" cy="65" r="2.5" opacity="0" filter="url(#orbGlow2)">
                  <animate attributeName="cy" values="65;155;65" dur="4.4s" begin="1.2s" repeatCount="indefinite"/>
                  <animate attributeName="opacity" values="0;1;1;1;0" keyTimes="0;0.1;0.45;0.85;1" dur="4.4s" begin="1.2s" repeatCount="indefinite"/>
                </circle>
              </g>

              <!-- blocked cross-silo orbs (data tries to flow both ways, hits the wall, turns into an X) -->
              <!-- 1 → 2 -->
              <g>
                <circle class="orb-red" cy="100" r="2.5" opacity="0">
                  <animate attributeName="cx" values="114;154;154" keyTimes="0;0.6;1" dur="2.8s" begin="1.6s" repeatCount="indefinite"/>
                  <animate attributeName="opacity" values="0;1;1;0;0" keyTimes="0;0.1;0.55;0.6;1" dur="2.8s" begin="1.6s" repeatCount="indefinite"/>
                </circle>
                <g class="x-mark" transform="translate(156 100)" opacity="0">
                  <line x1="-4" y1="-4" x2="4" y2="4"/>
                  <line x1="-4" y1="4"  x2="4" y2="-4"/>
                  <animate attributeName="opacity" values="0;0;1;1;0" keyTimes="0;0.58;0.62;0.85;1" dur="2.8s" begin="1.6s" repeatCount="indefinite"/>
                </g>
              </g>
              <!-- 2 → 1 -->
              <g>
                <circle class="orb-red" cy="140" r="2.5" opacity="0">
                  <animate attributeName="cx" values="156;116;116" keyTimes="0;0.6;1" dur="2.8s" begin="2.3s" repeatCount="indefinite"/>
                  <animate attributeName="opacity" values="0;1;1;0;0" keyTimes="0;0.1;0.55;0.6;1" dur="2.8s" begin="2.3s" repeatCount="indefinite"/>
                </circle>
                <g class="x-mark" transform="translate(114 140)" opacity="0">
                  <line x1="-4" y1="-4" x2="4" y2="4"/>
                  <line x1="-4" y1="4"  x2="4" y2="-4"/>
                  <animate attributeName="opacity" values="0;0;1;1;0" keyTimes="0;0.58;0.62;0.85;1" dur="2.8s" begin="2.3s" repeatCount="indefinite"/>
                </g>
              </g>
              <!-- 2 → 3 -->
              <g>
                <circle class="orb-red" cy="220" r="2.5" opacity="0">
                  <animate attributeName="cx" values="244;284;284" keyTimes="0;0.6;1" dur="2.8s" begin="3.0s" repeatCount="indefinite"/>
                  <animate attributeName="opacity" values="0;1;1;0;0" keyTimes="0;0.1;0.55;0.6;1" dur="2.8s" begin="3.0s" repeatCount="indefinite"/>
                </circle>
                <g class="x-mark" transform="translate(286 220)" opacity="0">
                  <line x1="-4" y1="-4" x2="4" y2="4"/>
                  <line x1="-4" y1="4"  x2="4" y2="-4"/>
                  <animate attributeName="opacity" values="0;0;1;1;0" keyTimes="0;0.58;0.62;0.85;1" dur="2.8s" begin="3.0s" repeatCount="indefinite"/>
                </g>
              </g>
              <!-- 3 → 2 -->
              <g>
                <circle class="orb-red" cy="260" r="2.5" opacity="0">
                  <animate attributeName="cx" values="286;246;246" keyTimes="0;0.6;1" dur="2.8s" begin="3.7s" repeatCount="indefinite"/>
                  <animate attributeName="opacity" values="0;1;1;0;0" keyTimes="0;0.1;0.55;0.6;1" dur="2.8s" begin="3.7s" repeatCount="indefinite"/>
                </circle>
                <g class="x-mark" transform="translate(244 260)" opacity="0">
                  <line x1="-4" y1="-4" x2="4" y2="4"/>
                  <line x1="-4" y1="4"  x2="4" y2="-4"/>
                  <animate attributeName="opacity" values="0;0;1;1;0" keyTimes="0;0.58;0.62;0.85;1" dur="2.8s" begin="3.7s" repeatCount="indefinite"/>
                </g>
              </g>
            </svg>
          </div>

          <div class="diagram-col">
            <div class="diagram-label">With Habitat</div>
            <svg class="diagram-svg habitat-diagram" viewBox="0 0 460 400" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet">
              <defs>
                <filter id="orbGlowH" x="-300%" y="-300%" width="700%" height="700%">
                  <feGaussianBlur stdDeviation="2.6" result="b"/>
                  <feMerge>
                    <feMergeNode in="b"/>
                    <feMergeNode in="b"/>
                    <feMergeNode in="SourceGraphic"/>
                  </feMerge>
                </filter>
                <filter id="barGlowH" x="-20%" y="-300%" width="140%" height="700%">
                  <feGaussianBlur stdDeviation="7"/>
                </filter>
              </defs>

              <rect class="bar-glow" x="30" y="78" width="400" height="12" fill="#008000" filter="url(#barGlowH)" />

              <rect class="node" x="10" y="14" width="440" height="70" rx="1" />
              <text class="node-label lead-label" x="230" y="55" text-anchor="middle">your organization's data</text>

              <line class="connector" x1="70"  y1="84" x2="70"  y2="240" />
              <line class="connector" x1="180" y1="84" x2="180" y2="270" />
              <line class="connector" x1="280" y1="84" x2="280" y2="212" />
              <line class="connector" x1="390" y1="84" x2="390" y2="230" />

              <circle class="orb" cx="70" cy="84" r="3" opacity="0" filter="url(#orbGlowH)">
                <animate attributeName="cy" values="84;240" dur="2.8s" begin="0s" repeatCount="indefinite"/>
                <animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.12;0.88;1" dur="2.8s" begin="0s" repeatCount="indefinite"/>
              </circle>
              <circle class="orb" cx="180" cy="84" r="3" opacity="0" filter="url(#orbGlowH)">
                <animate attributeName="cy" values="84;270" dur="2.8s" begin="0.7s" repeatCount="indefinite"/>
                <animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.12;0.88;1" dur="2.8s" begin="0.7s" repeatCount="indefinite"/>
              </circle>
              <circle class="orb" cx="280" cy="84" r="3" opacity="0" filter="url(#orbGlowH)">
                <animate attributeName="cy" values="84;212" dur="2.8s" begin="1.4s" repeatCount="indefinite"/>
                <animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.12;0.88;1" dur="2.8s" begin="1.4s" repeatCount="indefinite"/>
              </circle>
              <circle class="orb" cx="390" cy="84" r="3" opacity="0" filter="url(#orbGlowH)">
                <animate attributeName="cy" values="84;230" dur="2.8s" begin="2.1s" repeatCount="indefinite"/>
                <animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.12;0.88;1" dur="2.8s" begin="2.1s" repeatCount="indefinite"/>
              </circle>

              <!-- shared-data branches: one point on the data bar feeds both docs editor and agents -->
              <path id="shareToDocs" class="connector" d="M125 84 C 125 170, 70 170, 70 240" fill="none" />
              <path id="shareToAgents" class="connector" d="M125 84 C 125 150, 280 150, 280 212" fill="none" />
              <path id="shareToWorkflows" class="connector" d="M280 84 C 280 160, 390 160, 390 230" fill="none" />

              <circle class="orb" r="3" opacity="0" filter="url(#orbGlowH)">
                <animateMotion dur="2.8s" begin="1.05s" repeatCount="indefinite">
                  <mpath href="#shareToDocs"/>
                </animateMotion>
                <animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.12;0.88;1" dur="2.8s" begin="1.05s" repeatCount="indefinite"/>
              </circle>
              <circle class="orb" r="3" opacity="0" filter="url(#orbGlowH)">
                <animateMotion dur="2.8s" begin="1.05s" repeatCount="indefinite">
                  <mpath href="#shareToAgents"/>
                </animateMotion>
                <animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.12;0.88;1" dur="2.8s" begin="1.05s" repeatCount="indefinite"/>
              </circle>
              <circle class="orb" r="3" opacity="0" filter="url(#orbGlowH)">
                <animateMotion dur="2.8s" begin="1.75s" repeatCount="indefinite">
                  <mpath href="#shareToWorkflows"/>
                </animateMotion>
                <animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.12;0.88;1" dur="2.8s" begin="1.75s" repeatCount="indefinite"/>
              </circle>

              <rect class="node" x="20" y="240" width="100" height="80" rx="1" />
              <text class="node-label" x="70" y="276" text-anchor="middle">your</text>
              <text class="node-label" x="70" y="294" text-anchor="middle">docs app</text>

              <rect class="node" x="130" y="270" width="100" height="76" rx="1" />
              <text class="node-label" x="180" y="304" text-anchor="middle">your</text>
              <text class="node-label" x="180" y="322" text-anchor="middle">tasks app</text>

              <g transform="translate(270 220)">
                <path class="sparkle" d="M0 -10 L1.6 -1.6 L10 0 L1.6 1.6 L0 10 L-1.6 1.6 L-10 0 L-1.6 -1.6 Z"/>
              </g>
              <g transform="translate(297 238)">
                <path class="sparkle" d="M0 -7 L1.2 -1.2 L7 0 L1.2 1.2 L0 7 L-1.2 1.2 L-7 0 L-1.2 -1.2 Z"/>
              </g>
              <text class="node-label" x="283" y="280" text-anchor="middle">your agents</text>

              <rect class="node" x="340" y="230" width="100" height="130" rx="1" />
              <rect class="node sm" x="375" y="248" width="14" height="14" />
              <rect class="node sm" x="395" y="280" width="14" height="14" />
              <rect class="node sm" x="375" y="312" width="14" height="14" />

              <circle class="orb" cx="382" cy="255" r="2.6" opacity="0" filter="url(#orbGlowH)">
                <animate attributeName="cx" values="382;402;382;382" keyTimes="0;0.33;0.66;1" dur="3.6s" begin="2.4s" repeatCount="indefinite"/>
                <animate attributeName="cy" values="255;287;319;255" keyTimes="0;0.33;0.66;1" dur="3.6s" begin="2.4s" repeatCount="indefinite"/>
                <animate attributeName="opacity" values="0;1;1;1;0" keyTimes="0;0.08;0.5;0.92;1" dur="3.6s" begin="2.4s" repeatCount="indefinite"/>
              </circle>

              <text class="node-label" x="390" y="384" text-anchor="middle">your custom workflows</text>
            </svg>
          </div>
        </div>
      </div>
    </section>

    <!-- SECTION 2: PILLARS -->
    <section class="section pillars">
      <div class="section-inner">
        <h2 class="reveal">What we offer:</h2>

        <div class="schema-block">
          <div class="schema-text">
            <h3 class="reveal">Structured data in explorable schemas; LLM-friendly</h3>
            <p class="lead reveal" style="--d: 100ms">Data in Habitat is self-describing and easily parse-able by humans and agents alike. Access any type of data from any application; bypassing data siloes entirely.</p>
          </div>
          <img class="section-image reveal" style="--d: 200ms" src="/schemas.png" alt="" />
        </div>

        <div class="content-block">
          <div class="groups-block">
            <img class="groups-image reveal" style="--d: 200ms" src="/groups.png" alt="" />
            <div class="groups-text">
              <h3 class="reveal">Lifetime identity management and unified permissions</h3>
              <p class="lead reveal" style="--d: 100ms">We provide a permissioning layer that can be shared, so teams and roles persist across app boundaries. When someone leaves your organization, their data stays behind, preserving historical context. </p>
            </div>
          </div>
        </div>

        <div class="content-block" id="agents-block">
          <h3 class="reveal">Perfect for building agents and custom apps</h3>
          <p class="lead reveal" style="--d: 100ms">Habitat gives you a governed substrate to read from and write to, so you can build your own custom agentic workflows, with permissions and auditability intact. Run agents that inherit permissions from their creator and see exactly who—or whose agent—did what.</p>
        </div>
      </div>
    </section>


    <!-- SECTION 4: CLOSING -->
    <section class="section closing">
      <div class="section-inner center">
        <h2 class="reveal">Own your organization's data.</h2>
        <p class="lead reveal" style="--d: 100ms">
          Have a problem Habitat can help solve? <a href="https://calendly.com/arushi-habitat">Get in touch with us today.</a>
        </p>

      </div>
    </section>

  </main>
</Layout>

<style is:global>
  /* Shared landing base lives in src/styles/landing.css (imported above).
     Only index-specific rules go here. */

  /* Index hero is a two-column grid (copy + visual). Override the shared
     .landing .hero-inner padding/width with the grid layout. */
  .landing .hero-inner {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .hero-talk-to-us {
    display: flex;
    width: 100%;
    min-width: 0;
  }

  .hero-copy .waitlist {
    max-width: none;
  }

  .waitlist {
    display: flex;
    align-items: stretch;
    gap: 0;
    max-width: 460px;
    border-bottom: 1px solid var(--black);
  }
  .waitlist.center { margin: 28px auto 0; }
  .waitlist input {
    flex: 1;
    border: none;
    outline: none;
    padding: 14px 0;
    font: inherit;
    font-size: 1rem;
    background: transparent;
    color: var(--black);
  }
  .waitlist input::placeholder { color: var(--muted); }
  .waitlist button {
    border: none;
    background: transparent;
    color: var(--black);
    font: inherit;
    font-weight: 500;
    font-size: 1rem;
    padding: 14px 16px 14px 0;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: color 160ms ease;
  }
  .waitlist button:hover { color: var(--green); }
  .waitlist button span { transition: transform 200ms ease; }
  .waitlist button:hover span { transform: translateX(4px); }

  .waitlist-status {
    margin: 12px 0 0;
    min-height: 1.25rem;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.8125rem;
    color: var(--muted);
  }
  .waitlist-status[data-status="success"] { color: var(--green); }
  .waitlist-status[data-status="invalid"],
  .waitlist-status[data-status="error"] { color: var(--black); }
  .section.closing .waitlist-status { text-align: center; }

  /* ---------- HERO VISUAL ---------- */
  .hero-visual { width: 100%; }
  .plane {
    position: relative;
    aspect-ratio: 460 / 400;
    width: 100%;
    max-width: 540px;
    margin-left: auto;
    background: var(--white);
  }
  .diagram-svg {
    width: 100%;
    height: 100%;
    display: block;
    overflow: visible;
  }
  .diagram-svg.habitat-diagram {
    height: auto;
    max-width: 540px;
    margin-top: 8px;
  }

  /* ---------- HERO ABSTRACT ARTIFACT ---------- */
  .hero-art-wrap {
    position: relative;
    width: 100%;
    max-width: 560px;
    aspect-ratio: 5 / 6;
    margin-left: auto;
  }
  .hero-art {
    width: 100%;
    height: 100%;
    display: block;
  }
  .hero-falling-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 22%, black 100%);
    mask-image: linear-gradient(to right, transparent 0%, black 22%, black 100%);
  }
  .diagram-svg .node {
    fill: var(--white);
    stroke: var(--black);
    stroke-width: 1;
    vector-effect: non-scaling-stroke;
  }
  .diagram-svg .node.sm { stroke-width: 0.9; }
  .diagram-svg .sparkle {
    fill: none;
    stroke: var(--black);
    stroke-width: 1;
    stroke-linejoin: round;
    vector-effect: non-scaling-stroke;
  }
  .diagram-svg .node-label {
    font-family: 'General Sans', ui-sans-serif, system-ui, sans-serif;
    font-size: 12.5px;
    font-weight: 400;
    fill: var(--black);
    letter-spacing: 0.005em;
  }
  .diagram-svg .lead-label {
    font-size: 14px;
    font-weight: 450;
  }
  .diagram-svg .connector {
    stroke: rgba(0, 0, 0, 0.16);
    stroke-width: 1;
    vector-effect: non-scaling-stroke;
  }
  .diagram-svg .orb {
    fill: var(--green);
  }
  .diagram-svg .bar-glow {
    opacity: 0.35;
  }

  /* Closing section centers its heading + lead — index-specific. */
  .section.closing h2 { max-width: none; margin-left: auto; margin-right: auto; }
  .section.closing .lead { margin-left: auto; margin-right: auto; }

  .schema-block {
    display: flex;
    gap: 48px;
    align-items: center;
  }
  .schema-block .schema-text {
    flex: 1 1 40%;
    min-width: 280px;
  }
  .schema-block .section-image {
    flex: 0 0 38%;
    max-height: 315px;
    width: auto;
