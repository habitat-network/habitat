<script>
  function setupReveal() {
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            e.target.classList.add('is-visible');
            io.unobserve(e.target);
          }
        }
      },
      { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('.reveal:not(.is-visible)').forEach((el) => io.observe(el));
  }

  // Fires on initial page load AND after every view transition
  document.addEventListener('astro:page-load', setupReveal);
</script>

<script>
  const WAITLIST_URL = 'https://habitat-953995456319.us-west1.run.app/waitlist';
  const MESSAGES: Record<string, string> = {
    success: "Thanks for signing up! We can't wait to show you what we've been growing 🌱",
    invalid: "That email wasn't quite right. Please submit an email like abc@example.com.",
    error: "Hmm, that didn't work. Please try again.",
  };

  document.querySelectorAll<HTMLFormElement>('form.waitlist').forEach((form) => {
    const status = form.parentElement?.querySelector<HTMLParagraphElement>('.waitlist-status');
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const input = form.querySelector<HTMLInputElement>('input[name="email"]');
      if (!input || !status) return;
      const email = input.value.trim();
      status.dataset.status = 'idle';
      status.textContent = '';
      try {
        const res = await fetch(WAITLIST_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, from: 'landing' }),
        });
        if (res.ok) {
          status.dataset.status = 'success';
          status.textContent = MESSAGES.success;
          input.value = '';
        } else {
          const text = (await res.text()).trim().toLowerCase();
          const kind = text === 'invalid email address' ? 'invalid' : 'error';
          status.dataset.status = kind;
          status.textContent = MESSAGES[kind];
        }
      } catch {
        status.dataset.status = 'error';
        status.textContent = MESSAGES.error;
      }
    });
  });
</script>

<script>
  import Matter from 'matter-js';

  const WORLD_W = 500;
  const WORLD_H = 600;

  // 9 designated cells (avoid col 0; the fade mask hides it)
  const PILES = [
    { cx: 150, cy: 50 },
    { cx: 250, cy: 150 },
    { cx: 350, cy: 150 },
    { cx: 450, cy: 250 },
    { cx: 150, cy: 350 },
    { cx: 350, cy: 350 },
    { cx: 250, cy: 450 },
    { cx: 150, cy: 550 },
    { cx: 450, cy: 550 },
  ];

  // Per-cell start delays (s), so cells don't all begin at once
  const CELL_OFFSETS = [0.0, 0.55, 0.30, 0.45, 0.20, 0.70, 0.40, 0.60, 0.10];
  const SHAPES_MIN = 5;
  const SHAPES_MAX = 25;

  const canvas = document.querySelector<HTMLCanvasElement>('.hero-falling-canvas');
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (canvas && !reduceMotion) {
    const ctx = canvas.getContext('2d')!;
    const { Engine, World, Bodies, Body } = Matter;

    const engine = Engine.create();
    engine.gravity.y = 1.0;
    engine.gravity.scale = 0.0015;

    // Static walls per cell. Collision filter isolates each cell so shapes
    // falling toward cell A don't collide with the walls/floor of cell B.
    PILES.forEach((p, i) => {
      const cat = 1 << i;
      const opts = {
        isStatic: true,
        collisionFilter: { category: cat, mask: cat, group: 0 },
      };
      // Visible cell square spans cx±45, cy±45 (5px inset inside each 100-tile).
      World.add(engine.world, [
        Bodies.rectangle(p.cx, p.cy + 45 + 4, 90, 8, opts),      // floor
        Bodies.rectangle(p.cx - 45 - 4, p.cy, 8, 90, opts),      // left wall
        Bodies.rectangle(p.cx + 45 + 4, p.cy, 8, 90, opts),      // right wall
      ]);
    });

    type Drawn = Matter.Body & { __kind: 0 | 1 | 2 };
    const dynamicBodies: Drawn[] = [];

    function dropShape(pileIdx: number, slotIdx: number) {
      const p = PILES[pileIdx];
      const cat = 1 << pileIdx;
      const jitter = (Math.random() - 0.5) * 24;
      const x = p.cx + jitter;
      const y = p.cy - 60;
      const kind = ((pileIdx * 3 + slotIdx) % 3) as 0 | 1 | 2;
      const opts: Matter.IBodyDefinition = {
        collisionFilter: { category: cat, mask: cat, group: 0 },
        friction: 0.5,
        frictionStatic: 0.8,
        restitution: 0.12,
        density: 0.0025,
      };
      let body: Matter.Body;
      if (kind === 0) {
        body = Bodies.rectangle(x, y, 11, 11, opts);
      } else if (kind === 1) {
        body = Bodies.circle(x, y, 5.8, opts);
      } else {
        body = Bodies.polygon(x, y, 3, 8, opts);
      }
      Body.setAngle(body, Math.random() * Math.PI * 2);
      Body.setAngularVelocity(body, (Math.random() - 0.5) * 0.18);
      (body as Drawn).__kind = kind;
      World.add(engine.world, body);
      dynamicBodies.push(body as Drawn);
    }

    const start = () => {
      PILES.forEach((_, i) => {
        const count = SHAPES_MIN + Math.floor(Math.random() * (SHAPES_MAX - SHAPES_MIN + 1));
        for (let s = 0; s < count; s++) {
          const t = (CELL_OFFSETS[i] + s * 0.22) * 1000;
          setTimeout(() => dropShape(i, s), t);
        }
      });
    };

    // Resize canvas to its CSS box, with DPR scaling for crisp shapes
    function resize() {
      const rect = canvas.getBoundingClientRect();
      const dpr = window.devicePixelRatio || 1;
      canvas.width = Math.round(rect.width * dpr);
      canvas.height = Math.round(rect.height * dpr);
    }
    resize();
    window.addEventListener('resize', resize);

    let last = performance.now();
    let started = false;

    // Defer starting drops until the canvas scrolls into view, so the pile-up
    // is visible from the beginning instead of pre-settling off-screen.
    const visObs = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (e.isIntersecting && !started) {
          started = true;
          last = performance.now();
          start();
          visObs.disconnect();
        }
      }
    }, { threshold: 0.1 });
    visObs.observe(canvas);

    function frame(now: number) {
      const dt = Math.min(33, now - last);
      last = now;
      Engine.update(engine, dt);

      ctx.setTransform(1, 0, 0, 1, 0, 0);
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      const sx = canvas.width / WORLD_W;
      const sy = canvas.height / WORLD_H;
      ctx.scale(sx, sy);
      ctx.fillStyle = '#008000';
      for (const b of dynamicBodies) {
        if (b.__kind === 1) {
          ctx.beginPath();
          ctx.arc(b.position.x, b.position.y, (b as any).circleRadius || 5.8, 0, Math.PI * 2);
          ctx.fill();
        } else {
          const v = b.vertices;
          ctx.beginPath();
          ctx.moveTo(v[0].x, v[0].y);
          for (let k = 1; k < v.length; k++) ctx.lineTo(v[k].x, v[k].y);
          ctx.closePath();
          ctx.fill();
        }
      }
      requestAnimationFrame(frame);
    }
    requestAnimationFrame(frame);
  }
</script>
