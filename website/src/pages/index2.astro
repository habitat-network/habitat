---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import WaitlistForm from "../components/WaitlistForm";
import OldWayDiagram from "../components/OldWayDiagram.astro";
import HabitatWayDiagram from "../components/HabitatWayDiagram.astro";
import SeatsDiagram from "../components/SeatsDiagram.astro";

const capabilities = [
  {
    n: "01",
    title: "Cross-app workflows are trivial",
    body: "Build agentic workflows across all your data, without waiting on vendor integrations.",
  },
  {
    n: "02",
    title: "Your data, ready for AI",
    body: "Point agents at data you actually own — with permissions and audit trails intact.",
  },
  {
    n: "03",
    title: "No vendor lock-in",
    body: "Swap apps without a migration project. Your data never moved in the first place.",
  },
  {
    n: "04",
    title: "Rich access control, across apps",
    body: "One permissioning layer, shared across every app. The team in your docs is the team in your chat is the team in your repos.",
  },
  {
    n: "05",
    title: "Identity that outlives the seat",
    body: "Org-owned identities that persist. When someone leaves, their work stays with the org.",
  },
  {
    n: "06",
    title: "Admin app authorization",
    body: "Control which members can use which apps, and what data each app can touch.",
  },
  {
    n: "07",
    title: "Know where your data lives",
    body: "Answer \"where is our data?\" in one sentence, not a SOC2 packet.",
  },
];
---

<Layout title="habitat">
  <body class="alt-page flex flex-col min-h-screen bg-[#f4f4f4] text-[#1f1f1f]">
    <Header />

    <main class="flex flex-col">
      <!-- Hero -->
      <section class="hero relative px-6 md:px-16 pt-24 pb-32 overflow-hidden">
        <div class="dot-grid" aria-hidden="true"></div>
        <div class="relative max-w-5xl mx-auto flex flex-col gap-8">
          <span class="mono-label">habitat / data layer for organizations</span>
          <h1 class="hero-headline">
            Data ownership<br />for organizations<span class="cursor">_</span>
          </h1>
          <p class="hero-sub max-w-2xl">
            A unified data layer that your organization owns. Apps request access to your data — not the other way around.
          </p>
          <div class="flex flex-wrap gap-3 pt-2">
            <a href="#waitlist" class="btn-primary">Get on the waitlist</a>
            <a href="mailto:hello@habitat.network" class="btn-secondary">Talk to us</a>
          </div>
        </div>
      </section>

      <!-- 01 — the problem -->
      <section class="section problem px-6 md:px-16 py-24">
        <div class="max-w-6xl mx-auto">
          <div class="section-head">
            <h2>Your data isn't yours.</h2>
            <p>It lives in Notion, Linear, and Figma — siloed, gated, and held hostage to a dozen vendor contracts.</p>
          </div>
          <div class="diagram-card">
            <OldWayDiagram />
          </div>
        </div>
      </section>

      <!-- 02 — the solution -->
      <section class="section solution px-6 md:px-16 py-24">
        <div class="max-w-6xl mx-auto">
          <div class="section-head">
            <h2>One data layer. Many apps.</h2>
            <p>Your data lives in one place that you control. Apps come and go; your data stays.</p>
          </div>
          <div class="diagram-card">
            <HabitatWayDiagram />
          </div>
        </div>
      </section>

      <!-- 03 — capabilities -->
      <section class="section capabilities px-6 md:px-16 py-24">
        <div class="max-w-6xl mx-auto">
          <div class="section-head">
            <h2>What habitat offers</h2>
          </div>

          <!-- Featured: pay-per-seat with diagram -->
          <article class="card card-featured">
            <div class="flex flex-col md:flex-row gap-8 items-start">
              <div class="flex-1">
                <span class="mono-label">00 · featured</span>
                <h3>Pay for the people who actually use the product</h3>
                <p>Only the seats that use a product pay for it. Everyone else still has data access via habitat.</p>
              </div>
              <div class="flex-1 w-full">
                <SeatsDiagram />
              </div>
            </div>
          </article>

          <!-- Grid of remaining capabilities -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-6">
            {capabilities.map((c) => (
              <article class="card">
                <span class="mono-label">{c.n}</span>
                <h3>{c.title}</h3>
                <p>{c.body}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <!-- 04 — roadmap -->
      <section class="section roadmap px-6 md:px-16 py-24">
        <div class="max-w-6xl mx-auto">
          <div class="section-head">
            <h2>Coming soon</h2>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <article class="card card-soon">
              <span class="mono-label">soon</span>
              <h3>Agent identity platform</h3>
              <p>Run agents that inherit permissions from their creators.</p>
            </article>
            <article class="card card-soon">
              <span class="mono-label">soon</span>
              <h3>Audit logging</h3>
              <p>See exactly who (or whose agent) did what.</p>
            </article>
          </div>
        </div>
      </section>

      <!-- 05 — contact -->
      <section class="section contact px-6 md:px-16 py-24">
        <div class="max-w-6xl mx-auto">
          <div class="section-head">
            <h2>Talk to us.</h2>
            <p>If habitat sounds like something your organization could use, or you'd like to build on it as a developer.</p>
          </div>
          <div class="flex flex-wrap gap-3">
            <a href="mailto:hello@habitat.network" class="btn-primary">hello@habitat.network</a>
          </div>
        </div>
      </section>
    </main>

    <footer id="waitlist" class="section px-6 md:px-16 py-24 border-t border-[#1f1f1f]/10">
      <div class="max-w-6xl mx-auto flex flex-col items-start gap-6">
        <h2 class="footer-headline">Get updates.</h2>
        <WaitlistForm client:load from="index2" label="" />
      </div>
    </footer>
  </body>
</Layout>

<style is:global>
  .alt-page {
    font-feature-settings: "ss01", "cv01";
  }

  /* Monospace label */
  .alt-page .mono-label {
    font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas, monospace;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.55;
    color: #1f1f1f;
  }

  /* Hero */
  .alt-page .hero {
    background: #f4f4f4;
  }

  .alt-page .dot-grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(31, 31, 31, 0.16) 1px, transparent 1px);
    background-size: 22px 22px;
    mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.9), transparent 85%);
    -webkit-mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.9), transparent 85%);
    pointer-events: none;
  }

  .alt-page .hero-headline {
    font-size: clamp(2.5rem, 6vw, 4.75rem);
    font-weight: 800;
    line-height: 1.02;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .alt-page .cursor {
    display: inline-block;
    color: #1f1f1f;
    animation: blink 1.1s steps(1, end) infinite;
    margin-left: 2px;
  }

  @keyframes blink {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0; }
  }

  .alt-page .hero-sub {
    font-size: 1.15rem;
    line-height: 1.55;
    opacity: 0.8;
  }

  /* Buttons */
  .alt-page .btn-primary,
  .alt-page .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.1rem;
    font-size: 0.95rem;
    font-weight: 500;
    border-radius: 6px;
    border: 1.5px solid #1f1f1f;
    transition: transform 120ms ease, background 120ms ease;
  }

  .alt-page .btn-primary {
    background: #1f1f1f;
    color: #fafafa;
  }

  .alt-page .btn-primary:hover {
    transform: translateY(-1px);
  }

  .alt-page .btn-secondary {
    background: transparent;
    color: #1f1f1f;
  }

  .alt-page .btn-secondary:hover {
    background: #1f1f1f;
    color: #fafafa;
  }

  /* Section heads */
  .alt-page .section-head {
    margin-bottom: 2.5rem;
    max-width: 42rem;
  }

  .alt-page .section-head h2 {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.015em;
    margin: 0.6rem 0 0.6rem;
    line-height: 1.1;
  }

  .alt-page .section-head p {
    font-size: 1.05rem;
    opacity: 0.75;
    line-height: 1.55;
    margin: 0;
  }

  /* Diagram card */
  .alt-page .diagram-card {
    background: #ffffff;
    border: 1px solid rgba(31, 31, 31, 0.12);
    border-radius: 14px;
    padding: 2rem;
    box-shadow: 0 1px 0 rgba(31, 31, 31, 0.04);
  }

  /* Capability cards */
  .alt-page .card {
    background: #ffffff;
    border: 1px solid rgba(31, 31, 31, 0.12);
    border-radius: 12px;
    padding: 1.5rem 1.5rem 1.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: border-color 160ms ease, transform 160ms ease;
  }

  .alt-page .card:hover {
    border-color: rgba(31, 31, 31, 0.4);
    transform: translateY(-1px);
  }

  .alt-page .card h3 {
    font-size: 1.15rem;
    font-weight: 700;
    margin: 0.25rem 0 0;
    letter-spacing: -0.005em;
  }

  .alt-page .card p {
    margin: 0;
    font-size: 0.98rem;
    line-height: 1.5;
    opacity: 0.78;
  }

  .alt-page .card-featured {
    background: #1f1f1f;
    color: #fafafa;
    border-color: #1f1f1f;
    padding: 2rem;
  }

  .alt-page .card-featured .mono-label {
    color: #fafafa;
    opacity: 0.55;
  }

  .alt-page .card-featured h3 {
    font-size: 1.4rem;
    margin-top: 0.5rem;
  }

  .alt-page .card-featured p {
    opacity: 0.78;
  }

  /* Soon cards: dashed border for a "draft" feel */
  .alt-page .card-soon {
    background: transparent;
    border-style: dashed;
  }

  /* Footer */
  .alt-page .footer-headline {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.015em;
    margin: 0;
  }

  /* Subtle section dividers */
  .alt-page .section + .section {
    border-top: 1px solid rgba(31, 31, 31, 0.06);
  }
</style>
