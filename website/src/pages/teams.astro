---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import WaitlistForm from "../components/WaitlistForm";
import { Image } from "astro:assets";
import treestop from "../assets/treestop_green.jpg";
---

<Layout title="Organizations">
  <body class="flex flex-col">
    <Header active="users" />
    <main class="flex flex-col items-center gap-16">
      <section class="relative w-full flex flex-col min-h-[70vh]">
        <Image src={treestop} alt="" class="absolute inset-0 w-full h-full object-cover object-bottom" />
        <div class="absolute inset-0" style="background: linear-gradient(to bottom, #f4f4f4 0%, transparent 40%);"></div>
        <div class="relative px-6 md:px-12 pt-24">
          <h1 class="text-wrap">Take back control of your data, with habitat.</h1>
        </div>
      </section>
      <div class="prose px-6">
        If you're thinking about 
      </div>
        <div class="prose px-6">
        <h2>Supported features:</h2>
        <ul>
            <li>Admin identity management and app authorization</li>
            <li>Rich, shared permissioning layer</li>
        </ul>
        <h4>Coming soon</h4>
        <ul>
            <li>Derived agent identities</li>
        </ul>
      </div>
    </main>
    <footer class="flex justify-center py-16 px-8 w-full">
      <div class="prose max-w-none w-full text-center">
          <WaitlistForm client:load from="user" label="Own your data, with habitat. Sign up for the waitlist now:" />
      </div>
    </footer>
  </body>
</Layout>
