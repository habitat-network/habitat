---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import "../styles/landing.css";

const communityCreateUrl = import.meta.env.DEV
  ? "https://frontend.local.habitat.network/community/create"
  : "https://habitat.network/habitat/community/create";
---

<Layout
  title="Community Platform — Habitat"
  description="A data ownership platform for communities."
>
  <Header />

  <!-- Calendly link widget begin -->
  <link href="https://assets.calendly.com/assets/external/widget.css" rel="stylesheet">
  <script src="https://assets.calendly.com/assets/external/widget.js" type="text/javascript" async></script>
  <!-- Calendly link widget end -->

  <main class="landing cp">
    <!-- HERO -->
    <section class="hero">
      <div class="hero-inner">
        <h2 class="display reveal" style="--d: 80ms">You bring the community, we bring the platform.</h2>
        <p class="hero-sub reveal" style="--d: 160ms">
          
        </p>
      </div>
    </section>

    <!-- SECTION: backend handled -->
    <section class="section section-community-apps">
      <div class="section-inner">
        <div class="section-text">
          <h2 class="reveal">Build apps that actually feel like your community.</h2>
          <p class="lead reveal" style="--d: 100ms">
             With Habitat as your data backend, you can create custom frontends and apps tailored to your community's needs. Rather than fragmenting your community across tools, build directly in an integrated UI. <a href="https://calendly.com/arushi-habitat">Get in touch to learn how.</a>
          </p>
        </div>
      </div>
      <img class="section-image reveal" style="--d: 200ms" src="/community-asset.png" alt="" />
    </section>

  

    <!-- SECTION: safe data -->
    <section class="section section-safe-data">
      <div class="section-inner">
        <div class="section-text section-text-right">
          <h2 class="reveal">We build the stuff an LLM probably shouldn't.</h2>
          <p class="lead reveal" style="--d: 100ms">
            Identities, authentication, permissioning, search. Focus on your community's experience and let Habitat handle the infra. Our platform is built to be flexible--to support your present and future needs.
          </p>
        </div>
      </div>
      <img class="section-image section-image-left reveal" style="--d: 200ms" src="/group-asset.png" alt="" />
    </section>

      <!-- SECTION: open protocols -->
    <section class="section">
      <div class="section-inner section-with-buttons">
        <div class="section-text">
          <h2 class="reveal">Open-source, open protocols, deployed anywhere.</h2>
          <p class="lead reveal" style="--d: 100ms">
            Habitat is fully open source and built on AT protocol, an open protocol for data portability and interoperability.
            Run it on our hosted service, deploy it to your own infrastructure, or even self-host. Your community's data is yours, forever.
          </p>
        </div>
        <div class="section-buttons reveal" style="--d: 200ms">
          <a class="cta-button cta-lime" href="https://habitat.network/habitat/api">Read the docs</a>
          <a class="cta-button cta-pink" href="" onclick="Calendly.initPopupWidget({url: 'https://calendly.com/arushi-habitat'});return false;">Talk to us</a>
        </div>
      </div>
    </section>

    <!-- CLOSING -->
    <section class="section closing">
      <div class="section-inner center">
        <h2 class="reveal">Give your community its own habitat.</h2>
        <div class="reveal" style="--d: 100ms; margin-bottom: 32px;">
          <a class="cta-button cta-green" href={communityCreateUrl} style="min-width:420px">Get started now →</a>
        </div>
        <form class="waitlist center reveal" style="--d: 180ms" novalidate>
          <label class="visually-hidden" for="email-cp">your email</label>
          <input id="email-cp" type="text" name="email" placeholder="your email" required />
          <button type="submit">Sign up to get updates from us<span aria-hidden="true">→</span></button>
        </form>
        <p class="waitlist-status reveal" style="--d: 260ms" data-status="idle" aria-live="polite"></p>
      </div>
    </section>
  </main>
</Layout>

<style is:global>
  /* Page-specific overrides: this hero is text-only, so use tighter padding
     and let the heading run wider than the index hero's two-column layout. */
  .landing.cp .hero { padding: 96px 0 80px; }
  .landing.cp .hero .cta-button { min-width: 300px; }
  .landing.cp .display { max-width: 18ch; }
  .landing.cp .hero-sub { max-width: 60ch; margin-bottom: 0; }
  .landing.cp .section h2 { max-width: 28ch; }
  .landing.cp .lead { max-width: 64ch; margin-bottom: 0; }

  .landing.cp .section-with-icon {
    display: grid;
    grid-template-columns: 1fr 64px;
    gap: 48px;
    align-items: center;
  }
  .landing.cp .section-icon {
    display: block;
    justify-self: end;
    color: var(--black);
  }

  .landing.cp .section-community-apps,
  .landing.cp .section-safe-data {
    position: relative;
    overflow: hidden;
  }
  .landing.cp .section-community-apps .section-text {
    max-width: 580px;
  }
  .landing.cp .section-text-right {
    max-width: 480px;
    margin-left: auto;
  }
  .landing.cp .section-image {
    display: block;
    position: absolute;
    top: 50%;
    right: 0;
    transform: translateY(-50%);
    width: 42%;
    max-width: 520px;
    height: auto;
  }
  .landing.cp .section-image-left {
    right: auto;
    left: 0;
  }

  .landing.cp .section-community-apps,
  .landing.cp .section-safe-data {
    border-bottom: none;
  }

  .landing.cp .section-with-buttons {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 48px;
    align-items: center;
  }
  .landing.cp .section-buttons {
    display: flex;
    flex-direction: column;
    gap: 16px;
    justify-self: end;
  }
  .landing.cp .cta-lime { background: var(--lime); }
  .landing.cp .cta-pink { background: var(--pink); }

  @media (max-width: 880px) {
    .landing.cp .hero { padding: 56px 0 64px; }
    .landing.cp .section-with-icon {
      grid-template-columns: 1fr;
    }
    .landing.cp .section-icon { display: none; }
    .landing.cp .section-with-buttons {
      grid-template-columns: 1fr;
    }
    .landing.cp .section-buttons {
      justify-self: stretch;
      flex-direction: row;
      margin-top: 32px;
    }
    .landing.cp .cta-button {
      flex: 1;
      min-width: 0;
    }
    .landing.cp .section-community-apps,
    .landing.cp .section-safe-data {
      overflow: visible;
    }
    .landing.cp .section-community-apps .section-text,
    .landing.cp .section-text-right {
      max-width: none;
      margin-left: 0;
    }
    .landing.cp .section-image {
      display: block;
      position: static;
      transform: none;
      width: 100%;
      max-width: none;
      margin-top: 32px;
      margin-bottom: 32px;
    }
  }

  @media (max-width: 640px) {
    .waitlist button {
      white-space: normal;
    }
  }

  .waitlist {
    display: flex;
    align-items: stretch;
    gap: 0;
    max-width: 460px;
    border-bottom: 1px solid var(--black);
  }
  .waitlist.center { margin: 28px auto 0; }
  .waitlist input {
    flex: 1;
    border: none;
    outline: none;
    padding: 14px 0;
    font: inherit;
    font-size: 1rem;
    background: transparent;
    color: var(--black);
  }
  .waitlist input::placeholder { color: var(--muted); }
  .waitlist button {
    border: none;
    background: transparent;
    color: var(--black);
    font: inherit;
    font-weight: 500;
    font-size: 1rem;
    padding: 14px 16px 14px 0;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    white-space: nowrap;
    transition: color 160ms ease;
  }
  .waitlist button:hover { color: var(--green); }
  .waitlist button span { transition: transform 200ms ease; }
  .waitlist button:hover span { transform: translateX(4px); }

  .waitlist-status {
    margin: 12px 0 0;
    min-height: 1.25rem;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.8125rem;
    color: var(--muted);
  }
  .waitlist-status[data-status="success"] { color: var(--green); }
  .waitlist-status[data-status="invalid"],
  .waitlist-status[data-status="error"] { color: var(--black); }
  .section.closing .waitlist-status { text-align: center; }
  .section.closing h2 { max-width: none; margin-left: auto; margin-right: auto; }
</style>

<script>
  function setupReveal() {
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            e.target.classList.add('is-visible');
            io.unobserve(e.target);
          }
        }
      },
      { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('.cp .reveal:not(.is-visible)').forEach((el) => io.observe(el));
  }

  document.addEventListener('astro:page-load', setupReveal);
</script>

<script>
  const WAITLIST_URL = 'https://habitat-953995456319.us-west1.run.app/waitlist';
  const MESSAGES = {
    success: "Thanks for signing up! We can't wait to show you what we've been growing \u{1F331}",
    invalid: "That email wasn't quite right. Please submit an email like abc@example.com.",
    error: "Hmm, that didn't work. Please try again.",
  };

  document.querySelectorAll<HTMLFormElement>('form.waitlist').forEach((form) => {
    const status = form.parentElement?.querySelector<HTMLParagraphElement>('.waitlist-status');
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const input = form.querySelector<HTMLInputElement>('input[name="email"]');
      if (!input || !status) return;
      const email = input.value.trim();
      status.dataset.status = 'idle';
      status.textContent = '';
      try {
        const res = await fetch(WAITLIST_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, from: 'landing' }),
        });
        if (res.ok) {
          status.dataset.status = 'success';
          status.textContent = MESSAGES.success;
          input.value = '';
        } else {
          const text = (await res.text()).trim().toLowerCase();
          const kind = text === 'invalid email address' ? 'invalid' : 'error';
          status.dataset.status = kind;
          status.textContent = MESSAGES[kind];
        }
      } catch {
        status.dataset.status = 'error';
        status.textContent = MESSAGES.error;
      }
    });
  });
</script>
