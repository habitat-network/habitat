---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import "../styles/landing.css";
---

<Layout
  title="Community Platform — Habitat"
  description="A data ownership platform for communities."
>
  <Header />

  <main class="landing cp">
    <!-- HERO -->
    <section class="hero">
      <div class="hero-inner">
        <h1 class="display reveal" style="--d: 80ms">Your community's data should belong to you.</h1>
        <p class="hero-sub reveal" style="--d: 160ms">
          Habitat's Community Platform is for groups that are ready to own their data and build for their unique needs, instead of using mass-produced software. Habitat gives you the foundation to reduce reliance on Big Tech, build custom apps, and collaborate with other communities.
        </p>
      </div>
    </section>

    <!-- SECTION: backend handled -->
    <section class="section">
      <div class="section-inner section-with-icon">
        <div class="section-text">
          <h2 class="reveal">Build for your community's needs; let Habitat handle the rest.</h2>
          <p class="lead reveal" style="--d: 100ms">
             With Habitat as your data backend, you can create custom frontends and apps tailored to your community's needs. Rather than paying for SaaS tools only to use one feature from each, build directly for your community's needs in an integrated UI. <a href="https://calendly.com/arushi-habitat">Get in touch to learn how.</a>
          </p>
        </div>
        <svg class="section-icon reveal" style="--d: 200ms" viewBox="0 0 48 48" width="48" height="48" fill="none" stroke="currentColor" stroke-width="1" shape-rendering="crispEdges" aria-hidden="true">
          <rect x="12" y="10" width="24" height="8"/>
          <rect x="16" y="20" width="20" height="8"/>
          <rect x="20" y="30" width="16" height="8"/>
        </svg>
      </div>
    </section>

    <!-- SECTION: open source -->
    <section class="section">
      <div class="section-inner section-with-icon">
        <div class="section-text">
          <h2 class="reveal">Open-source, open protocols, deployed anywhere.</h2>
          <p class="lead reveal" style="--d: 100ms">
            Habitat is fully open source and built on AT protocol, an open protocol for data portability and interoperability. 
            Run it on our hosted service, deploy it to your own infrastructure, or even self-host. Your community's data is your, forever.
          </p>
        </div>
        <svg class="section-icon reveal" style="--d: 200ms" viewBox="0 0 48 48" width="48" height="48" fill="none" stroke="currentColor" stroke-width="1" shape-rendering="crispEdges" aria-hidden="true">
          <rect x="14" y="18" width="20" height="20"/>
          <line x1="24" y1="8" x2="24" y2="18"/>
          <line x1="18" y1="12" x2="24" y2="8"/>
          <line x1="30" y1="12" x2="24" y2="8"/>
        </svg>
      </div>
    </section>

    <!-- SECTION: open protocols -->
    <section class="section">
      <div class="section-inner section-with-icon">
        <div class="section-text">
          <h2 class="reveal">Built-in primitives.</h2>
          <p class="lead reveal" style="--d: 100ms">
            Community members can login with their existing identities--Google or AT Protocol--so they don't need another password. We offer fine-grained
            permissioning APIs, admin app authorization, and developer convenience functions, so you can focus on your community's experience while Habitat handles the infra.
          </p>
        </div>
        <svg class="section-icon reveal" style="--d: 200ms" viewBox="0 0 48 48" width="48" height="48" fill="none" stroke="currentColor" stroke-width="1" shape-rendering="crispEdges" aria-hidden="true">
          <rect x="8" y="8" width="32" height="32"/>
          <line x1="8" y1="16" x2="40" y2="16"/>
          <line x1="8" y1="24" x2="40" y2="24"/>
          <line x1="8" y1="32" x2="40" y2="32"/>
          <line x1="16" y1="8" x2="16" y2="40"/>
          <line x1="24" y1="8" x2="24" y2="40"/>
          <line x1="32" y1="8" x2="32" y2="40"/>
        </svg>
      </div>
    </section>

    <!-- CLOSING -->
    <section class="section closing">
      <div class="section-inner center">
        <h2 class="reveal">Learn how to use Habitat for your community.</h2>
        <!-- Calendly link widget begin -->
        <link href="https://assets.calendly.com/assets/external/widget.css" rel="stylesheet">
        <script src="https://assets.calendly.com/assets/external/widget.js" type="text/javascript" async></script>
        <div class="reveal" style="--d: 100ms; margin-bottom: 32px;">
          <a href="" onclick="Calendly.initPopupWidget({url: 'https://calendly.com/arushi-habitat'});return false;">Talk to us</a>
        </div>
        <!-- Calendly link widget end -->
        <form class="waitlist center reveal" style="--d: 180ms" novalidate>
          <label class="visually-hidden" for="email-cp">your email</label>
          <input id="email-cp" type="text" name="email" placeholder="your email" required />
          <button type="submit">Join waitlist <span aria-hidden="true">→</span></button>
        </form>
        <p class="waitlist-status reveal" style="--d: 260ms" data-status="idle" aria-live="polite"></p>
      </div>
    </section>
  </main>
</Layout>

<style is:global>
  /* Page-specific overrides: this hero is text-only, so use tighter padding
     and let the heading run wider than the index hero's two-column layout. */
  .landing.cp .hero { padding: 96px 0 80px; }
  .landing.cp .display { max-width: 18ch; }
  .landing.cp .hero-sub { max-width: 60ch; margin-bottom: 0; }
  .landing.cp .section h2 { max-width: 28ch; }
  .landing.cp .lead { max-width: 64ch; margin-bottom: 0; }

  .landing.cp .section-with-icon {
    display: grid;
    grid-template-columns: 1fr 64px;
    gap: 48px;
    align-items: center;
  }
  .landing.cp .section-icon {
    display: block;
    justify-self: end;
    color: var(--black);
  }

  @media (max-width: 880px) {
    .landing.cp .hero { padding: 56px 0 64px; }
    .landing.cp .section-with-icon {
      grid-template-columns: 1fr;
    }
    .landing.cp .section-icon { display: none; }
  }

  .waitlist {
    display: flex;
    align-items: stretch;
    gap: 0;
    max-width: 460px;
    border-bottom: 1px solid var(--black);
  }
  .waitlist.center { margin: 28px auto 0; }
  .waitlist input {
    flex: 1;
    border: none;
    outline: none;
    padding: 14px 0;
    font: inherit;
    font-size: 1rem;
    background: transparent;
    color: var(--black);
  }
  .waitlist input::placeholder { color: var(--muted); }
  .waitlist button {
    border: none;
    background: transparent;
    color: var(--black);
    font: inherit;
    font-weight: 500;
    font-size: 1rem;
    padding: 14px 16px 14px 0;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: color 160ms ease;
  }
  .waitlist button:hover { color: var(--green); }
  .waitlist button span { transition: transform 200ms ease; }
  .waitlist button:hover span { transform: translateX(4px); }

  .waitlist-status {
    margin: 12px 0 0;
    min-height: 1.25rem;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.8125rem;
    color: var(--muted);
  }
  .waitlist-status[data-status="success"] { color: var(--green); }
  .waitlist-status[data-status="invalid"],
  .waitlist-status[data-status="error"] { color: var(--black); }
  .section.closing .waitlist-status { text-align: center; }
  .section.closing h2 { max-width: none; margin-left: auto; margin-right: auto; }
</style>

<script>
  const io = new IntersectionObserver(
    (entries) => {
      for (const e of entries) {
        if (e.isIntersecting) {
          e.target.classList.add('is-visible');
          io.unobserve(e.target);
        }
      }
    },
    { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('.cp .reveal').forEach((el) => io.observe(el));
</script>

<script>
  const WAITLIST_URL = 'https://habitat-953995456319.us-west1.run.app/waitlist';
  const MESSAGES = {
    success: "Thanks for signing up! We can't wait to show you what we've been growing \u{1F331}",
    invalid: "That email wasn't quite right. Please submit an email like abc@example.com.",
    error: "Hmm, that didn't work. Please try again.",
  };

  document.querySelectorAll<HTMLFormElement>('form.waitlist').forEach((form) => {
    const status = form.parentElement?.querySelector<HTMLParagraphElement>('.waitlist-status');
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const input = form.querySelector<HTMLInputElement>('input[name="email"]');
      if (!input || !status) return;
      const email = input.value.trim();
      status.dataset.status = 'idle';
      status.textContent = '';
      try {
        const res = await fetch(WAITLIST_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, from: 'landing' }),
        });
        if (res.ok) {
          status.dataset.status = 'success';
          status.textContent = MESSAGES.success;
          input.value = '';
        } else {
          const text = (await res.text()).trim().toLowerCase();
          const kind = text === 'invalid email address' ? 'invalid' : 'error';
          status.dataset.status = kind;
          status.textContent = MESSAGES[kind];
        }
      } catch {
        status.dataset.status = 'error';
        status.textContent = MESSAGES.error;
      }
    });
  });
</script>
